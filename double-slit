<script>
// ── Physical constants ───────────────────────────────────────────────────────
const H_PL  = 6.626e-34;   // Planck J·s
const M_E   = 9.109e-31;   // electron mass kg
const C_LT  = 2.998e8;     // speed of light m/s
const EV_J  = 1.602e-19;   // 1 eV in J
const PX_M  = 1e-9;        // 1 sim pixel = 1 nm

// ── Simulation geometry (sim pixels) ────────────────────────────────────────
const SIM_W  = 420, SIM_H = 256;
const SRC_X  = 16;
const BAR_X  = 128;   // barrier left edge
const BAR_W  = 11;    // barrier thickness
const SCR_X  = 370;   // screen left edge
const CY     = SIM_H >> 1;

// ── Wave / slit parameters ───────────────────────────────────────────────────
let lam = 15, d = 55, a = 10;
let qMode = true, paused = false, fireRate = 4;

// ── Precomputed wave arrays ──────────────────────────────────────────────────
let S0, C0, D0, S1, C1, D1;
const N = SIM_W * SIM_H;

function recompute() {
  S0 = new Float32Array(N); C0 = new Float32Array(N); D0 = new Float32Array(N);
  S1 = new Float32Array(N); C1 = new Float32Array(N); D1 = new Float32Array(N);
  const k  = (2 * Math.PI) / lam;
  const sx = BAR_X + BAR_W;
  const y0 = CY - d * 0.5;
  const y1 = CY + d * 0.5;
  const ph = k * sx; // phase offset to match incoming plane wave
  for (let y = 0; y < SIM_H; y++) {
    for (let x = sx; x < SIM_W; x++) {
      const i = y * SIM_W + x;
      const dx = x - sx;
      const r0 = Math.sqrt(dx*dx + (y-y0)*(y-y0)) + .5;
      const r1 = Math.sqrt(dx*dx + (y-y1)*(y-y1)) + .5;
      const kr0 = k*r0 + ph, kr1 = k*r1 + ph;
      S0[i] = Math.sin(kr0); C0[i] = Math.cos(kr0);
      S1[i] = Math.sin(kr1); C1[i] = Math.cos(kr1);
      D0[i] = 1 / Math.sqrt(r0*.05 + 1);
      D1[i] = 1 / Math.sqrt(r1*.05 + 1);
    }
  }
  rebuildCDF();
}

// ── Intensity & CDF sampling ─────────────────────────────────────────────────
let cdf = new Float32Array(SIM_H);
const L_SIM = SCR_X - BAR_X - BAR_W;

function getIntensity(y) {
  const dy = y - CY;
  const r  = Math.sqrt(dy*dy + L_SIM*L_SIM);
  const st = dy / r;
  if (qMode) {
    const phD = Math.PI * d * st / lam;
    const phA = Math.PI * a * st / lam;
    const intf = Math.cos(phD) ** 2;
    const sinc = phA === 0 ? 1 : Math.sin(phA) / phA;
    return intf * sinc * sinc;
  } else {
    const dy0 = y - (CY - d*.5), dy1 = y - (CY + d*.5);
    const f = (dyi) => {
      const ri = Math.sqrt(dyi*dyi + L_SIM*L_SIM);
      const si = dyi/ri;
      const phi = Math.PI*a*si/lam;
      return phi === 0 ? 1 : (Math.sin(phi)/phi)**2;
    };
    return .5*(f(dy0) + f(dy1));
  }
}

function rebuildCDF() {
  let s = 0;
  for (let y = 0; y < SIM_H; y++) { s += getIntensity(y); cdf[y] = s; }
  for (let y = 0; y < SIM_H; y++) cdf[y] /= s;
}

function sampleY() {
  const r = Math.random();
  let lo=0, hi=SIM_H-1;
  while(lo<hi){ const m=(lo+hi)>>1; if(cdf[m]<r) lo=m+1; else hi=m; }
  return lo + Math.random() - .5;
}

// ── Canvas ───────────────────────────────────────────────────────────────────
const canvas = document.getElementById('c');
const ctx    = canvas.getContext('2d');
let W, H, sX, sY;
function resize() {
  const r = canvas.getBoundingClientRect();
  W = canvas.width = Math.round(r.width);
  H = canvas.height = 440;
  sX = W / SIM_W; sY = H / SIM_H;
}
resize(); window.addEventListener('resize', resize);

const off = document.createElement('canvas');
off.width = SIM_W; off.height = SIM_H;
const octx = off.getContext('2d');
const imd  = octx.createImageData(SIM_W, SIM_H);
const px   = imd.data;

// Screen hits
const hits = new Float32Array(SIM_H);
let nHits = 0, maxH = 0;
function addHit(y) {
  const yi = Math.round(y);
  if (yi>=0 && yi<SIM_H) { hits[yi]++; nHits++; if(hits[yi]>maxH) maxH=hits[yi]; }
}

// ── Particles ────────────────────────────────────────────────────────────────
const parts = [];
let fireAcc = 0;

function firePart() {
  const ty = sampleY();
  const sy = (Math.random()<.5 ? CY-d*.5 : CY+d*.5) + (Math.random()-.5)*a;
  parts.push({x: SRC_X, y: CY, sy, ty, ph: 0});
}

// ── Render wave field ────────────────────────────────────────────────────────
function renderField(t) {
  const k = (2*Math.PI)/lam;
  const om = Math.PI*3; // visual frequency
  const ct = Math.cos(om*t), st_ = Math.sin(om*t);
  const y0 = CY - d*.5, y1 = CY + d*.5;
  const bxe = BAR_X + BAR_W;

  for (let y=0; y<SIM_H; y++) {
    for (let x=0; x<SIM_W; x++) {
      const i = y*SIM_W+x, idx=i<<2;
      let r,g,b;

      if (x < BAR_X) {
        // Incoming plane wave
        const ps = Math.sin(k*x - om*t);
        const u = (ps+1)*.5;
        r = u*8|0; g = (20+u*100)|0; b = (60+u*155)|0;

      } else if (x < bxe) {
        // Barrier
        const in0 = Math.abs(y-y0) < a*.5;
        const in1 = Math.abs(y-y1) < a*.5;
        if (in0||in1) {
          // Slit gap — wave passing through
          const ps = Math.sin(k*x - om*t);
          const u = (ps+1)*.5;
          r=(u*15)|0; g=(90+u*110)|0; b=(160+u*95)|0;
        } else {
          r=50; g=58; b=65;
        }

      } else if (x < SCR_X) {
        // Interference / diffraction field
        if (qMode) {
          let ps = .5*(D0[i]*(S0[i]*ct-C0[i]*st_) + D1[i]*(S1[i]*ct-C1[i]*st_));
          if (ps>=0){ r=(ps*65)|0; g=(ps*210)|0; b=(30+ps*225)|0; }
          else { const u=-ps; r=(u*140)|0; g=(u*20)|0; b=(30+u*185)|0; }
        } else {
          // Classical: show incoherent sum (no dark fringes)
          const p0=Math.abs(.5*D0[i]*(S0[i]*ct-C0[i]*st_));
          const p1=Math.abs(.5*D1[i]*(S1[i]*ct-C1[i]*st_));
          const ps=p0+p1;
          r=(ps*180)|0; g=(ps*110)|0; b=(ps*20)|0;
        }

      } else {
        r=4; g=4; b=7;
      }

      px[idx]=r; px[idx+1]=g; px[idx+2]=b; px[idx+3]=255;
    }
  }
  octx.putImageData(imd,0,0);
  ctx.drawImage(off,0,0,W,H);
}

// ── Render accumulated screen hits ───────────────────────────────────────────
function renderScreen() {
  if (!maxH) return;
  const sx = SCR_X*sX, sw = (SIM_W-SCR_X)*sX;
  // Faint theoretical curve
  for (let y=0; y<SIM_H; y++) {
    const I = getIntensity(y);
    ctx.fillStyle = qMode
      ? `rgba(32,208,255,${(I*.12).toFixed(3)})`
      : `rgba(255,160,60,${(I*.12).toFixed(3)})`;
    ctx.fillRect(sx, y*sY, sw*I, Math.max(1,sY));
  }
  // Accumulated hits
  for (let y=0; y<SIM_H; y++) {
    if (!hits[y]) continue;
    const frac = hits[y]/maxH;
    ctx.fillStyle = qMode
      ? `rgba(${(frac*60)|0},${(frac*215)|0},${(30+frac*225)|0},${.15+frac*.85})`
      : `rgba(${(frac*230)|0},${(frac*140)|0},${(frac*30)|0},${.15+frac*.85})`;
    ctx.fillRect(sx, y*sY, sw, Math.max(1.5,sY));
  }
}

// ── Render fringe tick marks ─────────────────────────────────────────────────
function renderTicks() {
  const mMax = Math.floor(d/lam);
  ctx.save();
  ctx.strokeStyle = 'rgba(255,220,80,.55)';
  ctx.fillStyle   = 'rgba(255,220,80,.5)';
  ctx.font = '8px monospace';
  ctx.lineWidth = 1;
  for (let m=-mMax; m<=mMax; m++) {
    const sinT = m*lam/d;
    if (Math.abs(sinT)>0.97) continue;
    const tanT = sinT/Math.sqrt(1-sinT*sinT);
    const yPx  = (CY + tanT*L_SIM)*sY;
    const bx   = SCR_X*sX;
    ctx.beginPath(); ctx.moveTo(bx,yPx); ctx.lineTo(bx-7,yPx); ctx.stroke();
    if (Math.abs(m)<=3) {
      ctx.textAlign='right';
      ctx.fillText(`m=${m}`, bx-9, yPx+3);
    }
  }
  ctx.restore();
}

// ── Render particles & labels ────────────────────────────────────────────────
function renderParts() {
  parts.forEach(p => {
    const dx=p.x*sX, dy=p.y*sY;
    ctx.beginPath(); ctx.arc(dx,dy,3.5,0,Math.PI*2);
    ctx.fillStyle = qMode ? 'rgba(100,230,255,.9)' : 'rgba(255,170,60,.9)';
    ctx.fill();
    ctx.beginPath(); ctx.arc(dx,dy,1.5,0,Math.PI*2);
    ctx.fillStyle='#fff'; ctx.fill();
  });
}

function renderLabels() {
  ctx.save();
  ctx.font='9px monospace'; ctx.fillStyle='rgba(180,200,230,.4)'; ctx.textAlign='center';
  ctx.fillText('SOURCE', SRC_X*sX, 14);
  ctx.fillText('SLITS', (BAR_X+BAR_W*.5)*sX, 14);
  ctx.fillText('SCREEN', (SCR_X+(SIM_W-SCR_X)*.5)*sX, 14);
  // Dashed lines from slits to screen
  const y0=(CY-d*.5)*sY, y1=(CY+d*.5)*sY, bx=(BAR_X+BAR_W)*sX, sx2=SCR_X*sX;
  ctx.strokeStyle='rgba(100,200,255,.2)'; ctx.lineWidth=.5;
  ctx.setLineDash([4,5]);
  [y0,y1].forEach(yy=>{ ctx.beginPath(); ctx.moveTo(bx,yy); ctx.lineTo(sx2,yy); ctx.stroke(); });
  ctx.setLineDash([]);
  ctx.restore();
}

// ── Main animation loop ──────────────────────────────────────────────────────
let t=0, lastTs=null;

function loop(ts) {
  if(!lastTs) lastTs=ts;
  const dt = Math.min((ts-lastTs)/1000,.033);
  lastTs=ts;

  if(!paused) {
    t += dt;
    fireAcc += dt;
    while(fireAcc >= 1/fireRate) { firePart(); fireAcc -= 1/fireRate; }

    const spd = 110; // sim px/s
    for(let i=parts.length-1; i>=0; i--) {
      const p=parts[i];
      p.x += spd*dt;
      if(p.ph===0) {
        // Travel diagonally from source center toward assigned slit
        const prog = (p.x - SRC_X) / Math.max(1, BAR_X - SRC_X);
        p.y = CY + (p.sy - CY) * Math.min(1, prog);
        if(p.x >= BAR_X + BAR_W) { p.ph=1; p.y=p.sy; }
      }
      if(p.ph===1) {
        const prog=(p.x-(BAR_X+BAR_W))/L_SIM;
        p.y=p.sy+(p.ty-p.sy)*Math.min(1,prog);
      }
      if(p.x>=SCR_X) { addHit(p.ty); parts.splice(i,1); }
    }
  }

  renderField(t);
  renderScreen();
  renderTicks();
  renderParts();
  renderLabels();

  document.getElementById('badge-hits').textContent = `Particles: ${nHits}`;
  requestAnimationFrame(loop);
}

recompute();
requestAnimationFrame(loop);

// ── Live readout ─────────────────────────────────────────────────────────────
function updateReadout() {
  const lm = lam*PX_M, dm = d*PX_M, am = a*PX_M, Lm = L_SIM*PX_M;
  const photEV  = (H_PL*C_LT/lm)/EV_J;
  const elecJ   = H_PL*H_PL/(2*M_E*lm*lm);
  const elecEV  = elecJ/EV_J;
  const elecStr = elecEV<.001 ? (elecEV*1000).toFixed(2)+' meV' : elecEV.toFixed(3)+' eV';
  const dyNm    = (lm*Lm/dm)/PX_M;
  const mMax    = Math.floor(d/lam);
  const mStr    = mMax>=3 ? `0, ±1, ±2, ±3` : `0, ±1${mMax>=2?', ±2':''}`;

  const rows = [
    ['Wavelength',      'λ',   `${lam} nm`,          'de Broglie: λ=h/p'],
    ['Slit separation', 'd',   `${d} nm`,             ''],
    ['Slit width',      'a',   `${a} nm`,             ''],
    ['Screen distance', 'L',   `${L_SIM} nm`,         ''],
    ['Fringe spacing',  'Δy',  `${dyNm.toFixed(1)} nm`, 'λL/d'],
    ['Fringe orders',   'm',   mStr,                  'd·sinθ=mλ'],
    ['Photon energy',   'E',   `${photEV.toFixed(1)} eV`, 'hc/λ'],
    ['Electron energy', 'KE',  elecStr,               'h²/2mλ²'],
    ['Particles fired', 'N',   `${nHits}`,            qMode?'Quantum':'Classical'],
  ];
  document.getElementById('readout').innerHTML = rows.map(([n,s,v,f])=>
    `<tr><td>${n}</td><td>${s}</td><td>${v}</td><td>${f}</td></tr>`
  ).join('');
}
setInterval(updateReadout, 380);

// ── UI helpers ───────────────────────────────────────────────────────────────
function setMode(q) {
  qMode = q;
  rebuildCDF();
  const bm = document.getElementById('badge-mode');
  const mb = document.getElementById('mode-bar');
  const md = document.getElementById('mdot');
  const mt = document.getElementById('mode-text');
  if(q) {
    bm.textContent='⚛ QUANTUM MODE — Interference ON'; bm.style.color='var(--cyan)';
    mb.className='mode-bar q'; md.style.background='var(--cyan)';
    mt.textContent='Quantum — wave interference active';
    document.getElementById('btn-q').className='q-on';
    document.getElementById('btn-c').className='';
  } else {
    bm.textContent='⚠ CLASSICAL MODE — Which-Path Detector ON'; bm.style.color='var(--red)';
    mb.className='mode-bar c'; md.style.background='var(--red)';
    mt.textContent='Classical — observation destroys interference';
    document.getElementById('btn-q').className='';
    document.getElementById('btn-c').className='c-on';
  }
}

document.getElementById('btn-q').onclick    = () => setMode(true);
document.getElementById('btn-c').onclick    = () => setMode(false);
document.getElementById('btn-reset').onclick = () => { hits.fill(0); nHits=0; maxH=0; parts.length=0; };
document.getElementById('btn-pause').onclick = function() {
  paused=!paused; lastTs=null;
  this.textContent=paused?'▶ Play':'⏸ Pause';
  this.classList.toggle('lit',paused);
};

document.getElementById('sl-l').oninput = function() {
  lam = +this.value;
  document.getElementById('lv').textContent=lam+' nm';
  const pe=(H_PL*C_LT/(lam*PX_M))/EV_J;
  const ee=H_PL*H_PL/(2*M_E*(lam*PX_M)**2)/EV_J;
  const es=ee<.001?(ee*1000).toFixed(2)+' meV':ee.toFixed(3)+' eV';
  document.getElementById('lsub').textContent=`Photon: ${pe.toFixed(1)} eV · Electron: ${es}`;
  recompute();
};
document.getElementById('sl-d').oninput = function() {
  d=+this.value;
  document.getElementById('dv').textContent=d+' nm';
  const mM=Math.floor(d/lam);
  document.getElementById('dsub').textContent=`Bright fringes: m = 0, ±1 ... ±${mM}`;
  recompute();
};
document.getElementById('sl-a').oninput = function() {
  a=+this.value; document.getElementById('av').textContent=a+' nm'; recompute();
};
document.getElementById('sl-r').oninput = function() {
  fireRate=+this.value; document.getElementById('rv').textContent=fireRate+' /s';
};
</script>
